{
  "name": "@component-forge/engine",
  "version": "0.1.0",
  "description": "Core component generation engine",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@component-forge/plugin-sdk": "workspace:*",
    "@component-forge/schema": "workspace:*",
    "@component-forge/templates-react": "workspace:*",
    "jiti": "^2.4.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}
