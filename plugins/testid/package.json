{
  "name": "@component-forge/plugin-testid",
  "version": "0.1.0",
  "description": "Component Forge plugin — inject data-testid into generated components",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@component-forge/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
